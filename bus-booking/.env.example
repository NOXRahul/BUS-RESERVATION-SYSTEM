# ─── Application ───────────────────────────────────────────
APP_NAME="BusBooking API"
APP_ENV=production          # development | staging | production
DEBUG=false
SECRET_KEY=your-super-secret-key-min-32-chars-change-this
API_V1_PREFIX=/api/v1

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/busbooking
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300          # seconds – search result cache
SEAT_LOCK_TTL=300            # seconds – seat hold timer (5 min)

# ─── JWT ────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=2

# ─── Razorpay ───────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_CURRENCY=INR
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME="BusBooking"
FRONTEND_URL=https://yourdomain.com

# ─── Celery ─────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Security ───────────────────────────────────────────────
ALLOWED_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]
RATE_LIMIT_PER_MINUTE=60

# ─── Sentry (optional) ──────────────────────────────────────
SENTRY_DSN=
